{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(hugo *)",
      "Bash(npx oxfmt *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(bash scripts/*)",
      "Bash(wc *)"
    ]
  }
}
